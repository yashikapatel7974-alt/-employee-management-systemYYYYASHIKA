PORT=5000
NODE_ENV=development

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=enterprise_ems
DB_PORT=5432

# Authentication
JWT_SECRET=dev_secret_key_12345
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=dev_refresh_secret_key_12345
